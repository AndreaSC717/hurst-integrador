<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.husrt.ui.estudiante.EstudiantePerfilController"
            fitToWidth="true" hbarPolicy="NEVER">
    <VBox spacing="16"
          alignment="TOP_CENTER">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
        <Label text="Mi perfil" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label fx:id="lblNombre" style="-fx-font-size: 14px;"/>
        <Label fx:id="lblCedula" style="-fx-text-fill: #555;"/>
        <Label fx:id="lblPrograma" style="-fx-text-fill: #555;"/>
        <Label fx:id="lblUniversidad" style="-fx-text-fill: #555;"/>
        <Label fx:id="lblEstado" style="-fx-text-fill: #555;"/>
        <Label fx:id="lblArl" style="-fx-text-fill: #555;"/>
        <Label fx:id="lblInduccion" style="-fx-text-fill: #555;"/>
        <Label fx:id="lblInscripcion" style="-fx-text-fill: #555;"/>

        <Separator/>
        <Label text="Progreso de prácticas (semestre actual)" style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
        <Label fx:id="lblPeriodo" style="-fx-text-fill: #555;"/>
        <ProgressBar fx:id="progressHoras" prefWidth="400" maxWidth="400"/>
        <Label fx:id="lblHorasResumen" wrapText="true" maxWidth="420" style="-fx-font-weight: bold;"/>
        <Label fx:id="lblHorasFaltantes" wrapText="true" maxWidth="420"/>

        <Separator/>
        <Label text="Últimos accesos (90 días)" style="-fx-font-weight: bold;"/>
        <TableView fx:id="tablaHistorial" prefHeight="180" maxWidth="520">
            <columns>
                <TableColumn fx:id="colEntrada" text="Entrada" prefWidth="130"/>
                <TableColumn fx:id="colSalida" text="Salida" prefWidth="130"/>
                <TableColumn fx:id="colHoras" text="Horas" prefWidth="60"/>
                <TableColumn fx:id="colResultado" text="Resultado" prefWidth="90"/>
            </columns>
        </TableView>

        <Separator/>
        <VBox spacing="8" alignment="CENTER">
            <Label text="Foto de perfil" style="-fx-font-weight: bold;"/>
            <ImageView fx:id="fotoPreview" fitWidth="140" fitHeight="140" preserveRatio="true"
                       style="-fx-border-color: #ccc; -fx-border-width: 1;"/>
            <HBox spacing="8" alignment="CENTER">
                <Button text="Subir foto" onAction="#onSubirFoto"/>
                <Button text="Quitar foto" onAction="#onQuitarFoto"/>
            </HBox>
            <Button text="Guardar cambios" onAction="#onGuardar" defaultButton="true"/>
        </VBox>
        <Label fx:id="msgPerfil" wrapText="true" maxWidth="420"/>
    </VBox>
</ScrollPane>
