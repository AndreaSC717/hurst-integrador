# Copie a .env y ajuste. docker compose carga .env automáticamente.
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_DATABASE=husrt
MYSQL_USER=husrt
MYSQL_PASSWORD=husrt_secret
MYSQL_PORT=3306

# Cliente Java (application.properties o variables)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=husrt
DB_USER=husrt
DB_PASSWORD=husrt_secret
